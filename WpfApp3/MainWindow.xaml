        <Border Grid.Row="1" Grid.Column="1" Background="#0E1320" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
