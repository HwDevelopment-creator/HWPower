                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🔧" FontSize="24" VerticalAlignment="Center"/>
                                            <TextBlock Text="IntelPPM Editor" Margin="10,0,0,0" Foreground="{StaticResource Text}" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
