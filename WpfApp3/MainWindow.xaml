                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0" LastChildFill="True" Margin="16,8">
                    <Button DockPanel.Dock="Right" Style="{StaticResource MicroButton}" Content="↗ Apri log" Click="LogOpen_Click" Margin="6,0,0,0"/>
