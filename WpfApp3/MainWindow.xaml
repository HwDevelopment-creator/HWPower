                                                <TextBlock Text="Strumento avanzato di diagnostica e gestione driver" Foreground="{StaticResource Info}" FontSize="10.5" FontWeight="SemiBold"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Foreground="{StaticResource TextMuted}" FontSize="12.5" TextWrapping="Wrap" Margin="0,8,0,0"
                                                   Text="Legge e modifica il valore Start del servizio intelppm in HKLM\SYSTEM\CurrentControlSet\Services\intelppm, senza aprire Regedit. Il valore Start decide QUANDO Windows carica il driver intelppm.sys all'avvio: non è un tweak prestazionale garantito. Le modifiche richiedono il riavvio."/>
                                        <Border Margin="0,12,0,0" Background="#2A1414" BorderBrush="#5A2A2A" BorderThickness="1" CornerRadius="8" Padding="12,9">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="⚠" FontSize="15" Foreground="{StaticResource Bad}" VerticalAlignment="Top"/>
                                                <TextBlock Margin="9,0,0,0" Foreground="#FCA5A5" FontSize="11.5" TextWrapping="Wrap"
                                                           Text="Impostare 4 (Disabled) disattiva la gestione P-State di Intel: può cambiare il comportamento di frequenza/risparmio energetico. Gli effetti dipendono da CPU, BIOS, microcode e versione di Windows. Usa con cognizione e sappi come ripristinare."/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- ROW 1: VALORE ATTUALE + SELETTORE -->
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="1.3*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- VALORE ATTUALE -->
                                    <Border Style="{StaticResource Card}" Margin="0,0,7,0">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource SectionTitle}" Text="🎯 Valore attuale"/>
                                            <TextBlock Style="{StaticResource SectionSub}" Text="Chiave: intelppm\Start"/>
                                            <Border Margin="0,12,0,0" Background="#0E1422" CornerRadius="10" Padding="16,14">
                                                <StackPanel>
                                                    <TextBlock Text="Current Start Value" Foreground="{StaticResource TextMuted}" FontSize="10.5"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                        <TextBlock x:Name="PpmCurrentValueNum" Text="—" Foreground="{StaticResource Accent}" FontSize="44" FontWeight="Bold"/>
                                                        <TextBlock x:Name="PpmCurrentValueName" Text="(Sconosciuto)" Foreground="{StaticResource Text}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" Margin="12,0,0,0" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                            <Button Style="{StaticResource MicroButton}" HorizontalAlignment="Left" Margin="0,12,0,0" Content="🔄 Rileggi dal registro" Click="RefreshIntelppm_Click"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- SELETTORE -->
                                    <Border Style="{StaticResource Card}" Grid.Column="1" Margin="7,0,0,0">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource SectionTitle}" Text="⚙ Cambia valore"/>
                                            <TextBlock Style="{StaticResource SectionSub}" Text="Seleziona con i RadioButton oppure dal menu a tendina, poi premi Applica."/>

                                            <StackPanel Margin="0,10,0,0">
                                                <RadioButton x:Name="PpmRadio0" GroupName="PpmStart" Foreground="{StaticResource Text}" FontSize="12.5" Margin="0,4" Content="0 — Boot Start  ·  carica il driver durante il boot" ToolTip="Driver caricato dal boot loader, prima del kernel. Molto raro per intelppm."/>
                                                <RadioButton x:Name="PpmRadio1" GroupName="PpmStart" Foreground="{StaticResource Text}" FontSize="12.5" Margin="0,4" Content="1 — System Start  ·  carica molto presto" ToolTip="Caricato durante l'inizializzazione del kernel."/>
                                                <RadioButton x:Name="PpmRadio2" GroupName="PpmStart" Foreground="{StaticResource Text}" FontSize="12.5" Margin="0,4" Content="2 — Automatic Start  ·  caricamento automatico" ToolTip="Caricato automaticamente all'avvio del sistema."/>
                                                <RadioButton x:Name="PpmRadio3" GroupName="PpmStart" Foreground="{StaticResource Text}" FontSize="12.5" Margin="0,4" Content="3 — Manual Start  ·  su richiesta (default tipico)" ToolTip="Caricato solo su richiesta. Valore predefinito comune per intelppm su Windows 10/11."/>
                                                <RadioButton x:Name="PpmRadio4" GroupName="PpmStart" Foreground="{StaticResource Text}" FontSize="12.5" Margin="0,4" Content="4 — Disabled  ·  driver disattivato" ToolTip="Il driver intelppm.sys non viene caricato."/>
                                            </StackPanel>

                                            <Grid Margin="0,14,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <ComboBox x:Name="PpmCombo" Width="220" Height="32" Padding="10,6" VerticalAlignment="Center"
                                                          Foreground="{StaticResource Text}" Background="#161E2E" BorderBrush="{StaticResource Border}"
                                                          SelectionChanged="PpmCombo_SelectionChanged">
                                                    <ComboBoxItem Content="0 - Boot Start"/>
                                                    <ComboBoxItem Content="1 - System Start"/>
                                                    <ComboBoxItem Content="2 - Automatic Start"/>
                                                    <ComboBoxItem Content="3 - Manual Start"/>
                                                    <ComboBoxItem Content="4 - Disabled"/>
                                                </ComboBox>
                                                <Button Grid.Column="1" Style="{StaticResource ActionButton}" Margin="10,0,0,0" Content="✓ Applica al registro" Click="ApplyIntelppm_Click"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- ROW 2: TABELLA DESCRIZIONE -->
                                <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitle}" Text="📖 Descrizione dei valori"/>
                                        <TextBlock Style="{StaticResource SectionSub}" Text="Significato di ciascun valore della chiave Start."/>
                                        <Border Margin="0,12,0,0" Background="#0E1422" CornerRadius="10">
                                            <StackPanel>
                                                <!-- header -->
                                                <Grid Margin="14,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="64"/>
                                                        <ColumnDefinition Width="170"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Valore" Foreground="{StaticResource TextDim}" FontSize="10.5" FontWeight="SemiBold"/>
                                                    <TextBlock Grid.Column="1" Text="Nome" Foreground="{StaticResource TextDim}" FontSize="10.5" FontWeight="SemiBold"/>
                                                    <TextBlock Grid.Column="2" Text="Descrizione" Foreground="{StaticResource TextDim}" FontSize="10.5" FontWeight="SemiBold"/>
                                                </Grid>

                                                <!-- row 0 -->
                                                <Border BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Padding="14,11">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="64"/>
                                                            <ColumnDefinition Width="170"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Background="#0E2A30" CornerRadius="6" Width="34" Height="26" HorizontalAlignment="Left">
                                                            <TextBlock Text="0" Foreground="{StaticResource Info}" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <TextBlock Grid.Column="1" Text="Boot Start" Foreground="{StaticResource Text}" FontWeight="SemiBold" FontSize="12.5" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="2" Text="Carica il driver durante il boot, prima del kernel. Raro per intelppm." Foreground="{StaticResource TextMuted}" FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>

                                                <!-- row 1 -->
                                                <Border BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Padding="14,11">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="64"/>
                                                            <ColumnDefinition Width="170"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Background="#0E2A30" CornerRadius="6" Width="34" Height="26" HorizontalAlignment="Left">
                                                            <TextBlock Text="1" Foreground="{StaticResource Info}" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <TextBlock Grid.Column="1" Text="System Start" Foreground="{StaticResource Text}" FontWeight="SemiBold" FontSize="12.5" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="2" Text="Carica molto presto, durante l'inizializzazione del kernel." Foreground="{StaticResource TextMuted}" FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>

                                                <!-- row 2 -->
                                                <Border BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Padding="14,11">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="64"/>
                                                            <ColumnDefinition Width="170"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Background="#0E2E22" CornerRadius="6" Width="34" Height="26" HorizontalAlignment="Left">
                                                            <TextBlock Text="2" Foreground="{StaticResource Good}" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <TextBlock Grid.Column="1" Text="Automatic Start" Foreground="{StaticResource Text}" FontWeight="SemiBold" FontSize="12.5" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="2" Text="Caricamento automatico all'avvio del sistema." Foreground="{StaticResource TextMuted}" FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>

                                                <!-- row 3 -->
                                                <Border BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Padding="14,11">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="64"/>
                                                            <ColumnDefinition Width="170"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Background="#11252F" CornerRadius="6" Width="34" Height="26" HorizontalAlignment="Left">
                                                            <TextBlock Text="3" Foreground="{StaticResource Accent}" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                            <TextBlock Text="Manual Start" Foreground="{StaticResource Text}" FontWeight="SemiBold" FontSize="12.5"/>
                                                            <Border Background="#11252F" CornerRadius="5" Padding="6,1" Margin="8,0,0,0">
                                                                <TextBlock Text="default" Foreground="{StaticResource Accent}" FontSize="9.5" FontWeight="SemiBold"/>
                                                            </Border>
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="2" Text="Caricamento su richiesta. Valore predefinito tipico di intelppm." Foreground="{StaticResource TextMuted}" FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>

                                                <!-- row 4 -->
                                                <Border BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Padding="14,11">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="64"/>
                                                            <ColumnDefinition Width="170"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Background="#2A1414" CornerRadius="6" Width="34" Height="26" HorizontalAlignment="Left">
                                                            <TextBlock Text="4" Foreground="{StaticResource Bad}" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                            <TextBlock Text="Disabled" Foreground="{StaticResource Text}" FontWeight="SemiBold" FontSize="12.5"/>
                                                            <Border Background="#2A1414" CornerRadius="5" Padding="6,1" Margin="8,0,0,0">
                                                                <TextBlock Text="⚠ attenzione" Foreground="{StaticResource Bad}" FontSize="9.5" FontWeight="SemiBold"/>
                                                            </Border>
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="2" Text="Driver disattivato: non viene caricato. Può influire su frequenza/risparmio." Foreground="{StaticResource TextMuted}" FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- ROW 3: STATO SISTEMA + AZIONI -->
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="1.1*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- STATO SISTEMA -->
                                    <Border Style="{StaticResource Card}" Margin="0,0,7,0">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource SectionTitle}" Text="🖥 Stato sistema"/>
                                            <Grid Margin="0,12,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="IntelPPM Driver" Foreground="{StaticResource TextMuted}" FontSize="12"/>
                                                <TextBlock x:Name="PpmDriverState" Grid.Column="1" Text="—" Foreground="{StaticResource Good}" FontSize="12.5" FontWeight="SemiBold"/>
                                            </Grid>
                                            <Grid Margin="0,9,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Valore Registro (Start)" Foreground="{StaticResource TextMuted}" FontSize="12"/>
                                                <TextBlock x:Name="PpmRegValueState" Grid.Column="1" Text="—" Foreground="{StaticResource Accent}" FontSize="12.5" FontWeight="SemiBold"/>
                                            </Grid>
                                            <Grid Margin="0,9,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Riavvio Richiesto" Foreground="{StaticResource TextMuted}" FontSize="12"/>
                                                <TextBlock x:Name="PpmRebootState" Grid.Column="1" Text="No" Foreground="{StaticResource Good}" FontSize="12.5" FontWeight="SemiBold"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- AZIONI -->
                                    <Border Style="{StaticResource Card}" Grid.Column="1" Margin="7,0,0,0">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource SectionTitle}" Text="🛠 Azioni"/>
                                            <TextBlock Style="{StaticResource SectionSub}" Text="Strumenti rapidi per gestione e verifica."/>
                                            <WrapPanel Margin="0,12,0,0">
                                                <Button Style="{StaticResource ActionButton}" Margin="0,0,8,8" Content="✓ Applica al registro" Click="ApplyIntelppm_Click"/>
                                                <Button Style="{StaticResource GhostButton}" Margin="0,0,8,8" Content="📋 Apri Gestione Attività" Click="OpenTaskManager_Click"/>
                                                <Button Style="{StaticResource GhostButton}" Margin="0,0,8,8" Content="🔍 Apri Regedit (intelppm)" Click="OpenIntelppmRegistry_Click"/>
                                                <Button Style="{StaticResource GhostButton}" Margin="0,0,0,8" Content="♻ Ripristina predefinito (3)" Click="RestoreIntelppmDefault_Click"/>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- ROW 4: GUIDA VERIFICA FREQUENZA -->
                                <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitle}" Text="⚡ Come verificare la frequenza della CPU"/>
                                        <TextBlock Style="{StaticResource SectionSub}" Text="Per controllare l'effetto reale della modifica, usa Gestione Attività dopo il riavvio."/>
                                        <StackPanel Margin="0,10,0,0">
                                            <TextBlock Foreground="{StaticResource TextMuted}" FontSize="12.5" Margin="0,2" Text="1.  Apri Gestione Attività (pulsante qui sopra)."/>
                                            <TextBlock Foreground="{StaticResource TextMuted}" FontSize="12.5" Margin="0,2" Text="2.  Vai nella scheda Prestazioni."/>
                                            <TextBlock Foreground="{StaticResource TextMuted}" FontSize="12.5" Margin="0,2" Text="3.  Seleziona CPU."/>
                                            <TextBlock Foreground="{StaticResource TextMuted}" FontSize="12.5" Margin="0,2" Text="4.  Guarda il campo &quot;Velocità&quot; e confronta i valori prima e dopo il riavvio."/>
                                            <Border Margin="0,10,0,0" Background="#0E1422" CornerRadius="8" Padding="12,9">
                                                <TextBlock Foreground="{StaticResource TextDim}" FontSize="11" TextWrapping="Wrap"
                                                           Text="Nota: la &quot;Velocità&quot; mostrata da altri strumenti (Win32_Processor.CurrentClockSpeed o PerformanceCounter) può essere imprecisa o in ritardo, soprattutto sulle CPU Intel moderne. Gestione Attività usa contatori del kernel ed è il riferimento più affidabile."/>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- LOG -->
                                <Border Style="{StaticResource Card}" Margin="0,0,0,0">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitle}" Text="📝 Registro modifiche"/>
                                        <TextBlock x:Name="IntelppmLogText" Foreground="{StaticResource TextMuted}" FontSize="11.5" FontFamily="Cascadia Mono, Consolas" TextWrapping="Wrap" Margin="0,8,0,0" Text="Pronto per le modifiche..."/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- ============ NETWORK ============ -->
                    <Grid x:Name="ViewNetwork" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Style="{StaticResource Card}" Margin="0,0,7,14">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitle}" Text="🚀 TCP Optimization"/>
                                        <TextBlock Style="{StaticResource SectionSub}" Text="Autotuning, ECN, RSS, Nagle off."/>
                                        <Button Style="{StaticResource ActionButton}" HorizontalAlignment="Left" Content="Applica TCP tweaks" Click="TcpTweaks_Click"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}" Grid.Column="1" Margin="7,0,0,14">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitle}" Text="🌐 DNS"/>
                                        <TextBlock Style="{StaticResource SectionSub}" Text="Cloudflare / Google / Quad9."/>
                                        <WrapPanel>
                                            <Button Style="{StaticResource ActionButton}" Content="Cloudflare"  Margin="0,0,8,8" Click="DnsCloudflare_Click"/>
                                            <Button Style="{StaticResource ActionButton}" Content="Google"      Margin="0,0,8,8" Click="DnsGoogle_Click"/>
                                            <Button Style="{StaticResource ActionButton}" Content="Quad9"       Margin="0,0,8,8" Click="DnsQuad9_Click"/>
                                            <Button Style="{StaticResource GhostButton}"  Content="Auto (DHCP)" Margin="0,0,8,8" Click="DnsAuto_Click"/>
                                            <Button Style="{StaticResource GhostButton}"  Content="Flush DNS"   Margin="0,0,8,8" Click="FlushDns_Click"/>
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}" Grid.Row="1" Margin="0,0,7,14">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitle}" Text="⏱ Network Throttling"/>
                                        <TextBlock Style="{StaticResource SectionSub}" Text="Migliora il ping in gaming."/>
                                        <Button Style="{StaticResource ActionButton}" HorizontalAlignment="Left" Content="Disattiva throttling" Click="NetThrottlingOff_Click"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}" Grid.Row="1" Grid.Column="1" Margin="7,0,0,14">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitle}" Text="🔢 IPv6"/>
                                        <TextBlock Style="{StaticResource SectionSub}" Text="Disattiva se ISP non lo supporta."/>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Style="{StaticResource DangerButton}" Content="Disattiva" Margin="0,0,8,0" Click="Ipv6Off_Click"/>
                                            <Button Style="{StaticResource GoodButton}"   Content="Attiva" Click="Ipv6On_Click"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}" Grid.Row="2" Grid.ColumnSpan="2" Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitle}" Text="🔁 Network Reset"/>
                                        <TextBlock Style="{StaticResource SectionSub}" Text="Winsock + reset IP. Riavvio richiesto."/>
                                        <Button Style="{StaticResource WarnButton}" HorizontalAlignment="Left" Content="Reset stack" Click="NetReset_Click"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}" Grid.Row="3" Grid.ColumnSpan="2" Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitle}" Text="📶 Speed / Latency Test"/>
                                        <TextBlock Style="{StaticResource SectionSub}" Text="Ping a Cloudflare/Google/Quad9 + download 10 MB."/>
                                        <Button Style="{StaticResource ActionButton}" HorizontalAlignment="Left" Content="Avvia test" Click="NetSpeedTest_Click"/>
                                        <TextBlock x:Name="NetTestResult" Text="" Foreground="{StaticResource Accent}" FontFamily="Cascadia Mono, Consolas" FontSize="12" Margin="0,10,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </ScrollViewer>
                    </Grid>

                    <!-- ============ DEBLOAT ============ -->
                    <Grid x:Name="ViewDebloat" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="AppsSearchBox" TextChanged="AppsSearchBox_TextChanged" Margin="0,0,10,0"/>
                            <Button Grid.Column="1" Style="{StaticResource MicroButton}" Content="☑ Tutti" Margin="0,0,4,0" Click="AppsSelectAll_Click"/>
                            <Button Grid.Column="2" Style="{StaticResource MicroButton}" Content="☐ Nessuno" Margin="0,0,4,0" Click="AppsSelectNone_Click"/>
                            <Button Grid.Column="3" Style="{StaticResource WarnButton}"  Content="✓ Solo bloat" Margin="0,0,8,0" Click="AppsSelectBloat_Click"/>
                            <Button Grid.Column="4" Style="{StaticResource GhostButton}" Content="↻ Aggiorna" Margin="0,0,8,0" Click="AppsRefresh_Click"/>
                            <Button Grid.Column="5" Style="{StaticResource DangerButton}" Content="✕ Rimuovi selezionate" Click="AppsRemove_Click"/>
                        </Grid>
                        <TextBlock Grid.Row="1" x:Name="AppsSelInfo" Text="0 app selezionate" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="2,10,0,8"/>
                        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
                            <DataGrid x:Name="AppsGrid">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Header="✓" Width="40"
                                        Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    <DataGridTextColumn Header="App"       Binding="{Binding Name}"           Width="*"   IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Publisher" Binding="{Binding Publisher}"      Width="260" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Consiglio" Binding="{Binding Recommendation}" Width="130" IsReadOnly="True"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>

                    <!-- ============ STARTUP ============ -->
                    <Grid x:Name="ViewStartup" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" Foreground="{StaticResource TextMuted}" FontSize="13"
                                       Text="Spunta le voci e clicca 'Disabilita selezionate'."/>
                            <Button Grid.Column="1" Style="{StaticResource MicroButton}" Content="☑ Tutti" Margin="0,0,4,0" Click="StartupSelectAll_Click"/>
                            <Button Grid.Column="2" Style="{StaticResource MicroButton}" Content="☐ Nessuno" Margin="0,0,8,0" Click="StartupSelectNone_Click"/>
                            <Button Grid.Column="3" Style="{StaticResource GhostButton}"  Content="↻ Aggiorna" Margin="0,0,8,0" Click="StartupRefresh_Click"/>
                            <Button Grid.Column="4" Style="{StaticResource DangerButton}" Content="✕ Disabilita selezionate" Click="StartupRemove_Click"/>
                        </Grid>
                        <TextBlock Grid.Row="1" x:Name="StartupSelInfo" Text="0 voci selezionate" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="2,10,0,8"/>
                        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
                            <DataGrid x:Name="StartupGrid">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Header="✓" Width="40"
                                        Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    <DataGridTextColumn Header="Nome"     Binding="{Binding Name}"     Width="240" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Comando"  Binding="{Binding Command}"  Width="*"   IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Sorgente" Binding="{Binding Location}" Width="220" IsReadOnly="True"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>

                    <!-- ============ SYSTEM / DIAGNOSTICA ============ -->
                    <Grid x:Name="ViewSystem" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Style="{StaticResource Card}" Margin="0,0,6,0">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource StatLabel}" Text="CPU"/>
